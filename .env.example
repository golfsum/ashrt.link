# Copy to ".env" and fill in.

# Port the server listens on (local dev only; ignored on Vercel).
PORT=4000

# Public base of the service. In production set this to your canonical domain so
# short links and OAuth redirect URIs read as https://www.ashrt.link/...
BASE_URL=https://www.ashrt.link

# Secret used to sign login session cookies. Use a long random string.
# If unset it falls back to API_KEY. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=

# Optional legacy/admin key. Per-user API keys (from each account's page) are the
# normal way to authenticate the API now; this is no longer required.
API_KEY=

# --- Social login (optional) -------------------------------------------------
# Leave a provider's pair blank to hide its button. Redirect/callback URLs:
#   Google:  {BASE_URL}/auth/google/callback
#   GitHub:  {BASE_URL}/auth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Billing (optional, for the Pro plan) ------------------------------------
# Leave blank to ship free-only; the upgrade button shows "coming soon".
# STRIPE_PRICE_ID is a recurring (subscription) Price from your Stripe dashboard.
# Webhook endpoint to register in Stripe: {BASE_URL}/api/billing/webhook
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# --- Storage -----------------------------------------------------------------
# Leave blank for local dev (JSON files: .links.json + .users.json).
# On Vercel, add a KV / Upstash store and these are injected automatically, so
# links and accounts persist across serverless invocations (required there).
KV_REST_API_URL=
KV_REST_API_TOKEN=
