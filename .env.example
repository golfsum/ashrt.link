# Copy to ".env" and fill in.

# Port the server listens on.
PORT=4000

# Public base of the service. In production set this to your domain so the
# short links read as https://ashrt.link/abc123
BASE_URL=https://ashrt.link

# Shared key for creating/listing/deleting links (the redirect stays public).
# Use a long random string. Schedlytics sends this same key to mint links.
API_KEY=

# Storage. Leave these blank for local dev (a JSON file is used).
# On Vercel, add a Vercel KV / Upstash store and these are injected automatically,
# so links persist across serverless invocations.
KV_REST_API_URL=
KV_REST_API_TOKEN=
